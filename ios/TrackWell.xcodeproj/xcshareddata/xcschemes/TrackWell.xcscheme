                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "13B07F861A680F5B00A75B9A"
                     BuildableName = "TrackWell.app"
                     BlueprintName = "TrackWell"
                     ReferencedContainer = "container:TrackWell.xcodeproj">
